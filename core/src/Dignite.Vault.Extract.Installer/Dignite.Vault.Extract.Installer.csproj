<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="..\..\..\common.props"/>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
    <RootNamespace>Dignite.Vault.Extract</RootNamespace>
    <Description>ABP Studio module installer package for Dignite Vault Extract, carrying the module definition files used when installing the module into a solution.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Volo.Abp.VirtualFileSystem"/>
  </ItemGroup>

  <ItemGroup>
    <None Remove="..\..\Dignite.Vault.Extract.abpmdl"/>
    <Content Include="..\..\Dignite.Vault.Extract.abpmdl">
      <Pack>true</Pack>
      <PackagePath>content\</PackagePath>
    </Content>
    <None Remove="..\..\**\*.abppkg*" />
    <Content Include="..\..\**\*.abppkg*">
      <Pack>true</Pack>
      <PackagePath>content\</PackagePath>
    </Content>
  </ItemGroup>

</Project>