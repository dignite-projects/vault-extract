    <PackageReference Include="Volo.Abp.Auditing" />
    <PackageReference Include="Volo.Abp.Ddd.Application" />
    <PackageReference Include="Volo.Abp.Mapperly" />
    <ProjectReference Include="..\Dignite.Extract.Abstractions\Dignite.Extract.Abstractions.csproj" />
    <ProjectReference Include="..\Dignite.Extract.Application.Contracts\Dignite.Extract.Application.Contracts.csproj" />
