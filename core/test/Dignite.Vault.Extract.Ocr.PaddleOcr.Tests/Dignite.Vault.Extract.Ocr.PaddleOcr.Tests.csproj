<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="..\..\..\common.test.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <RootNamespace>Dignite.Vault.Extract.Ocr.PaddleOcr</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Pure unit tests: stub IHttpClientFactory to return an HttpClient backed by a recording
         HttpMessageHandler, so the PaddleOCR sidecar HTTP boundary is faked entirely in-process. Verifies
         request mapping (endpoint, multipart fields), structured-Markdown pass-through vs. raw_text->Markdown
         wrapping, native-payload archival, and error->exception. No real sidecar is contacted. -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="Shouldly" />
    <!-- For ExposedServiceExplorer in the DI-registration regression test. -->
    <PackageReference Include="Volo.Abp.Core" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Dignite.Vault.Extract.Ocr.PaddleOcr\Dignite.Vault.Extract.Ocr.PaddleOcr.csproj" />
  </ItemGroup>

</Project>
