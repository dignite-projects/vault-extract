<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="..\..\..\common.test.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <RootNamespace>Dignite.Vault.Extract</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- ABP web integration tests: spin up the MVC pipeline (AbpWebApplicationFactoryIntegratedTest) over an
         in-memory SQLite database, then drive the REST controllers through a real HttpClient. Reuses the EF
         Core test module (SQLite + Application + Domain + always-allow-auth + data seeding) so only the HTTP
         egress is added on top. -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="Shouldly" />
    <PackageReference Include="Volo.Abp.AspNetCore.TestBase" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Dignite.Vault.Extract.HttpApi\Dignite.Vault.Extract.HttpApi.csproj" />
    <ProjectReference Include="..\Dignite.Vault.Extract.EntityFrameworkCore.Tests\Dignite.Vault.Extract.EntityFrameworkCore.Tests.csproj" />
  </ItemGroup>

</Project>
