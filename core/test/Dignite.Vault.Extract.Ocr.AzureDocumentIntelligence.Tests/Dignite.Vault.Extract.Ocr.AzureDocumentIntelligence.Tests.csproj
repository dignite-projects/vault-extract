<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="..\..\..\common.test.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <RootNamespace>Dignite.Vault.Extract.Ocr.AzureDocumentIntelligence</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Pure unit tests: override the provider's CreateClient() seam to inject a DocumentIntelligenceClient
         backed by an Azure.Core HttpClientTransport over a fake HttpMessageHandler, so the Azure DI SDK's
         long-running-operation flow (POST 202 + Operation-Location, GET succeeded) runs entirely in-process.
         Verifies request mapping (prebuilt-layout + Markdown output format), Markdown pass-through, language
         detection, native-payload archival, and error->exception. No Azure resource is contacted. -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="Shouldly" />
    <!-- For ExposedServiceExplorer in the DI-registration regression test. -->
    <PackageReference Include="Volo.Abp.Core" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Dignite.Vault.Extract.Ocr.AzureDocumentIntelligence\Dignite.Vault.Extract.Ocr.AzureDocumentIntelligence.csproj" />
  </ItemGroup>

</Project>
