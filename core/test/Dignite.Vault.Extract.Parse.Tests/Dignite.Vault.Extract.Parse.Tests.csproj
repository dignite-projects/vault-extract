<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="..\..\..\common.test.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <RootNamespace>Dignite.Vault.Extract.Parse</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Pure unit tests for the DefaultTextExtractor orchestrator: NSubstitute the IOcrProvider and the
         IMarkdownTextProvider side-contract, construct the extractor with new(...). No ABP TestBase, no DB,
         no real provider module. Deliberately complements the AbpIntegratedTest-based DefaultTextExtractor /
         MarkdownProviderDispatch tests in Application.Tests (which wire the real ElBruno catch-all): this
         project isolates the orchestrator's branch logic to reach paths the integration tests cannot — the
         no-capable-provider throw (no catch-all is ever installed there), the same-priority tie-break, the
         half-filled native-payload drop, and exhaustive image-extension dispatch. -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="Shouldly" />
    <!-- For ExposedServiceExplorer in the DI-registration regression test. -->
    <PackageReference Include="Volo.Abp.Core" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Dignite.Vault.Extract.Parse\Dignite.Vault.Extract.Parse.csproj" />
  </ItemGroup>

</Project>
