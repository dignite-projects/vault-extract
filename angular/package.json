{
  "name": "vault-extract-workspace",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "nx serve host",
    "build": "nx run-many -t build",
    "build:vault-extract": "nx build vault-extract",
    "build:host": "nx build host",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "nx run-many -t lint",
    "generate-proxy": "nx g @abp/nx.generators:generate-proxy --module=vault-extract --apiName=Default --source=host --target=vault-extract --url=https://localhost:44348 --serviceType=application --no-interactive",
    "affected:build": "nx affected -t build",
    "affected:test": "vitest run"
  },
  "dependencies": {
    "@abp/ng.account": "~10.2.0",
    "@abp/ng.components": "~10.2.0",
    "@abp/ng.core": "~10.2.0",
    "@abp/ng.feature-management": "~10.2.0",
    "@abp/ng.identity": "~10.2.0",
    "@abp/ng.oauth": "~10.2.0",
    "@abp/ng.setting-management": "~10.2.0",
    "@abp/ng.theme.lepton-x": "~5.2.0",
    "@abp/ng.theme.shared": "~10.2.0",
    "@angular/animations": "~21.0.0",
    "@angular/aria": "~21.1.0",
    "@angular/common": "~21.0.0",
    "@angular/compiler": "~21.0.0",
    "@angular/core": "~21.0.0",
    "@angular/forms": "~21.0.0",
    "@angular/localize": "~21.0.0",
    "@angular/platform-browser": "~21.0.0",
    "@angular/platform-browser-dynamic": "~21.0.0",
    "@angular/router": "~21.0.0",
    "marked": "^18.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.1.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@abp/ng.schematics": "~10.2.0",
    "@abp/nx.generators": "~10.2.0",
    "@angular-devkit/build-angular": "~21.0.0",
    "@angular-eslint/builder": "~21.0.0",
    "@angular-eslint/eslint-plugin": "~21.0.0",
    "@angular-eslint/eslint-plugin-template": "~21.0.0",
    "@angular-eslint/schematics": "~21.0.0",
    "@angular-eslint/template-parser": "~21.0.0",
    "@angular/build": "~21.0.0",
    "@angular/cli": "~21.0.0",
    "@angular/compiler-cli": "~21.0.0",
    "@angular/language-service": "~21.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/utils": "^7.0.0",
    "eslint": "^8.23.0",
    "jsdom": "^27.1.0",
    "lerna": "^8.0.0",
    "ng-packagr": "~21.0.0",
    "nx": "^21.0.0",
    "typescript": "~5.9.0",
    "vitest": "^4.0.0"
  }
}
